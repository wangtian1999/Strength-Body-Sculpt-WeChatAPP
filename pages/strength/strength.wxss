.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.level-tag {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: 4rpx;
  font-weight: bold;
}

.level-tag.untrained { background: #666; color: #fff; }
.level-tag.novice { background: #4caf50; color: #fff; }
.level-tag.intermediate { background: #2196f3; color: #fff; }
.level-tag.elite { background: #f44336; color: #fff; }

.strength-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.strength-card {
  border-left: 10rpx solid #333;
}

.strength-card.squat { border-left-color: #e91e63; }
.strength-card.bench { border-left-color: #2196f3; }
.strength-card.deadlift { border-left-color: #ffc107; }

.range {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}

.tip {
  font-size: 20rpx;
  color: #666;
}

.adjustment-card {
  padding: 30rpx;
}

.adj-row {
  margin-bottom: 30rpx;
}

.adj-row .label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #888;
}

.tip-highlight {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(255, 193, 7, 0.1);
  border: 1rpx solid rgba(255, 193, 7, 0.3);
  color: #ffc107;
  font-size: 22rpx;
  line-height: 1.5;
}