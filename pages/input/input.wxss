.ios-item-vertical {
  display: flex;
  flex-direction: column;
  padding: 16px;
  border-bottom: 0.5px solid var(--ios-light-gray);
}

.ios-item-vertical:last-child {
  border-bottom: none;
}

.ios-item-vertical .label {
  font-size: 13px;
  color: var(--ios-text-gray);
  margin-bottom: 12px;
}

.ios-radio-group {
  display: flex;
  background: var(--ios-light-gray);
  padding: 2px;
  border-radius: 8px;
}

.ios-radio-label {
  padding: 4px 16px;
  font-size: 13px;
  border-radius: 6px;
}

.ios-radio-label.active {
  background: #636366;
  color: #fff;
}

.range-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.range-item {
  background: var(--ios-light-gray);
  padding: 8px 4px;
  text-align: center;
  font-size: 12px;
  border-radius: 8px;
  color: #fff;
}

.range-item.active {
  background: #fff;
  color: #000;
}

.ios-input {
  text-align: right;
  font-size: 17px;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.link-apple {
  color: var(--ios-blue);
  font-size: 13px;
}

.ios-slider {
  margin: 10px 0;
}

.stats-item {
  justify-content: space-around;
  padding: 20px 0;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 11px;
  color: var(--ios-text-gray);
  margin-bottom: 4px;
}

.stat-val {
  font-size: 17px;
  font-weight: 600;
}

.level-badge-ios {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
  background: var(--ios-light-gray);
}

.level-badge-ios.novice { color: var(--ios-green); }
.level-badge-ios.intermediate { color: var(--ios-blue); }

.ios-footer-tip {
  font-size: 12px;
  color: var(--ios-text-gray);
  text-align: center;
  margin: 20px 0;
  padding: 0 20px;
}

/* 移除冗余的 Modal 样式，已移至 app.wxss */
.picker-value-ios {
  font-size: 17px;
  color: #fff;
  display: flex;
  align-items: center;
}

.arrow {
  color: var(--ios-text-gray);
  margin-left: 8px;
  font-size: 14px;
}

.sbd-estimate-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 0.5px solid var(--ios-light-gray);
  background: rgba(255, 255, 255, 0.03);
}

.sbd-estimate-item {
  display: flex;
  flex-direction: column;
}

.sbd-estimate-item .lab {
  font-size: 11px;
  color: var(--ios-text-gray);
  text-transform: uppercase;
  margin-bottom: 4px;
}

.sbd-estimate-item .val {
  font-size: 17px;
  font-weight: 700;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.sbd-estimate-item .unit {
  font-size: 12px;
  font-weight: 400;
  color: var(--ios-text-gray);
  margin-left: 4px;
}