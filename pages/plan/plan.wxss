/** plan.wxss - Apple Style Purged **/
.progress-container-ios {
  padding: 20px;
}

.label-row-plan {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  padding: 0 16px;
}

.section-title {
  font-size: 17px;
  font-weight: 600;
}

.link-apple {
  color: var(--ios-blue);
  font-size: 13px;
}

.progress-grid-ios {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}

.progress-dot-ios {
  width: 40px;
  height: 40px;
  background: var(--ios-light-gray);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.progress-dot-ios.active {
  border: 2px solid #fff;
}

.progress-dot-ios.completed {
  background: var(--ios-green);
}

.week-num-ios {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
}

.progress-stats-ios {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
  color: var(--ios-text-gray);
}

.strength-badge-ios {
  background: #fff;
  color: #000;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 600;
}

.timer-overlay-ios {
  position: fixed;
  top: 60px;
  left: 16px;
  right: 16px;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(20px);
  border-radius: 20px;
  padding: 16px 24px;
  display: flex;
  align-items: center;
  z-index: 100;
}

.timer-content-ios {
  display: flex;
  align-items: center;
  width: 100%;
}

.timer-label-ios {
  font-size: 13px;
  color: #fff;
  opacity: 0.8;
  flex: 1;
}

.timer-clock-ios {
  font-size: 24px;
  font-weight: 700;
  margin-right: 20px;
}

.timer-close-ios {
  background: rgba(255,255,255,0.2);
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.plan-card-ios {
  padding: 0;
}

.exercise-item-ios {
  border-bottom: 0.5px solid var(--ios-light-gray);
}

.exercise-item-ios:last-child {
  border-bottom: none;
}

.ex-main-ios {
  display: flex;
  align-items: center;
  padding: 16px;
}

.ex-check-ios {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 1px solid var(--ios-light-gray);
  margin-right: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ex-check-ios.checked {
  background: var(--ios-green);
  border-color: var(--ios-green);
}

.ex-info-ios {
  flex: 1;
}

.ex-name-ios {
  font-size: 17px;
  font-weight: 500;
  display: block;
}

.ex-params-ios {
  font-size: 13px;
  color: var(--ios-text-gray);
}

.ex-timer-btn-ios {
  font-size: 13px;
  color: var(--ios-blue);
}

.ex-detail-ios {
  background: #111;
  padding: 16px;
  font-size: 13px;
}

.detail-section-ios {
  margin-bottom: 12px;
}

.detail-section-ios:last-child {
  margin-bottom: 0;
}

.detail-label-ios {
  color: var(--ios-text-gray);
  display: block;
  margin-bottom: 4px;
}

.detail-text-ios {
  line-height: 1.6;
}

.action-group-ios {
  margin-top: 32px;
  margin-bottom: 50px;
}
