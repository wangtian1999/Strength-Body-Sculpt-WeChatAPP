.plan-summary {
  display: flex;
  justify-content: space-between;
  border-bottom: 2rpx solid #333;
}

.summary-item {
  display: flex;
  flex-direction: column;
}

.summary-item .value {
  font-size: 32rpx;
  font-weight: bold;
}

.growth-card {
  padding: 25rpx;
  background: #0d0d0d;
}

.growth-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.growth-diff {
  font-size: 32rpx;
  color: #4caf50;
  font-weight: bold;
  font-family: 'Courier New', Courier, monospace;
}

.growth-chart-sim {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
}

.chart-point {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-val {
  font-size: 28rpx;
  font-family: 'Courier New', Courier, monospace;
}

.chart-val.highlight {
  color: #4caf50;
  font-size: 36rpx;
  font-weight: bold;
}

.chart-label {
  font-size: 18rpx;
  color: #666;
  margin-top: 5rpx;
}

.chart-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, #333, #4caf50);
  margin: 0 20rpx;
  position: relative;
  top: -15rpx;
}

.week-selector {
  white-space: nowrap;
  margin-bottom: 30rpx;
  background: #0a0a0a;
  padding: 10rpx 0;
}

.week-tab {
  display: inline-block;
  padding: 20rpx 40rpx;
  color: #888;
  font-family: 'Courier New', Courier, monospace;
}

.week-tab.active {
  color: #fff;
  border-bottom: 4rpx solid #fff;
  font-weight: bold;
}

.day-card {
  border: 1rpx solid #333;
  margin-bottom: 30rpx;
  background: #111;
}

.day-header {
  padding: 15rpx 30rpx;
  background: #222;
  font-size: 24rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #333;
}

.exercise-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #222;
  transition: all 0.3s;
}

.exercise-row.completed {
  background: rgba(76, 175, 80, 0.05);
  opacity: 0.6;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #444;
  margin-right: 20rpx;
  border-radius: 4rpx;
  position: relative;
}

.checkbox.checked {
  background: #4caf50;
  border-color: #4caf50;
}

.checkbox.checked::after {
  content: '✓';
  color: #fff;
  font-size: 28rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.ex-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.ex-meta {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.warmup-badge {
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  background: #333;
  color: #ffc107;
  border-radius: 4rpx;
}

.ex-note {
  font-size: 20rpx;
  color: #ff9800;
  margin-top: 5rpx;
}

.ex-data {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.ex-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 5rpx;
}

.ex-name {
  font-size: 28rpx;
}

.swap-btn {
  font-size: 18rpx;
  color: #2196f3;
  border: 1rpx solid #2196f3;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.nutrition-card {
  background: #0a0a0a;
  border: 1rpx solid #333;
}

.macro-summary {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #222;
}

.macro-item {
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.p-dot, .c-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}
.p-dot { background: #4caf50; }
.c-dot { background: #2196f3; }

.food-grid {
  display: flex;
  gap: 40rpx;
}

.food-col {
  flex: 1;
}

.food-title {
  font-size: 20rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  margin-bottom: 10rpx;
  color: #eee;
}

.food-amount {
  font-weight: bold;
  color: #fff;
}

.ex-rest {
  font-size: 20rpx;
  color: #555;
  font-family: 'Courier New', Courier, monospace;
}

.ex-sets {
  font-size: 22rpx;
  color: #888;
}

.ex-weight {
  font-size: 32rpx;
  font-weight: bold;
  color: #4caf50;
}

.safety-box {
  margin: 30rpx 0;
  padding: 25rpx;
  background: #1a1a1a;
  border-left: 6rpx solid #f44336;
}

.safety-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #f44336;
  margin-bottom: 15rpx;
}

.safety-box text {
  display: block;
  font-size: 20rpx;
  color: #aaa;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.tip-box {
  margin-top: 40rpx;
  padding: 30rpx;
  border: 1rpx dashed #333;
  font-size: 22rpx;
  color: #666;
}

.tip-box text {
  display: block;
  margin-bottom: 10rpx;
}