<view class="container">
  <view class="large-title">训练计划</view>

  <!-- 全局进度矩阵 Apple Activity Style -->
  <view class="section-header">12周进化矩阵</view>
  <view class="ios-group progress-container-ios">
    <view class="label-row-plan">
      <text class="section-title">进化矩阵</text>
      <text class="link-apple" bindtap="toggleBFRef">体脂参考图</text>
    </view>
    <view class="progress-grid-ios">
      <view wx:for="{{12}}" wx:key="index" 
            class="progress-dot-ios {{index + 1 === currentWeek ? 'active' : ''}} {{index + 1 < currentWeek ? 'completed' : ''}}"
            bindtap="selectWeek" data-week="{{index + 1}}">
        <text class="week-num-ios">{{index + 1}}</text>
      </view>
    </view>
    <view class="progress-stats-ios">
      <view class="stat-left">
        <text>已完成 {{currentWeek - 1}} / 12 周</text>
        <view class="ios-tip">建议：每周训练 3 次，练一休一，给肌肉恢复时间</view>
      </view>
      <text class="strength-badge-ios">{{strengthLevel.label}}</text>
    </view>
  </view>

  <!-- 休息计时器 Floating Apple Style -->
  <view class="timer-overlay-ios" wx:if="{{timerActive}}">
    <view class="timer-content-ios">
      <text class="timer-label-ios">休息中</text>
      <text class="timer-clock-ios">{{timerDisplay}}</text>
      <view class="timer-close-ios" bindtap="stopTimer">取消</view>
    </view>
  </view>

  <!-- 能量评分 & 状态调整 -->
  <view class="section-header">今日状态调整</view>
  <view class="ios-group energy-card-ios">
    <view class="label-row">
      <text class="label">精力评分: {{energyScore}} 分</text>
      <text class="energy-tip-ios">{{energyScore <= 2 ? '⚠️ 建议减载' : (energyScore >= 4 ? '🚀 状态爆表' : '⚖️ 状态正常')}}</text>
    </view>
    <slider class="ios-slider" min="1" max="5" step="1" value="{{energyScore}}" bindchange="onEnergyChange" activeColor="#fff" />
    <view class="ios-tip">根据评分自动调整今日训练重量与组数</view>
  </view>

  <!-- 训练卡片 -->
  <view wx:for="{{weeklyPlan}}" wx:for-item="day" wx:for-index="dayIndex" wx:key="dayIndex">
    <view class="section-header">{{day.day}}</view>
    <view class="ios-group plan-card-ios">
      <view class="exercise-list-ios">
        <view wx:for="{{day.exercises}}" wx:for-item="item" wx:for-index="exIndex" wx:key="id" class="exercise-item-ios">
          <view class="ex-main-ios" bindtap="toggleExDetail" data-dayindex="{{dayIndex}}" data-exindex="{{exIndex}}">
            <view class="ex-check-ios {{completedTasks[item.id] ? 'checked' : ''}}" catchtap="toggleComplete" data-dayindex="{{dayIndex}}" data-exindex="{{exIndex}}">
              <icon type="success_no_circle" size="12" color="#000" wx:if="{{completedTasks[item.id]}}" />
            </view>
            <view class="ex-info-ios">
              <text class="ex-name-ios">{{item.name}}</text>
              <text class="ex-params-ios">{{item.sets}}组 x {{item.reps}}次 / {{item.weight}}{{item.weight === '自重' || item.weight === '持续' ? '' : 'kg'}}</text>
            </view>
            <view class="ex-timer-btn-ios" catchtap="startTimer" data-sec="{{item.restSec || 180}}">⏱ 计时</view>
          </view>
          
          <!-- 动作详情展开 -->
          <view class="ex-detail-ios" wx:if="{{item.showDetail}}">
            <view class="detail-section-ios" wx:if="{{item.tip}}">
              <text class="detail-label-ios">💡 动作要领</text>
              <text class="detail-text-ios">{{item.tip}}</text>
            </view>
            <view class="detail-section-ios" wx:if="{{item.regression}}">
              <text class="detail-label-ios">⬇️ 退阶建议</text>
              <text class="detail-text-ios">{{item.regression}}</text>
            </view>
            <view class="detail-section-ios" wx:if="{{item.progression}}">
              <text class="detail-label-ios">⬆️ 进阶建议</text>
              <text class="detail-text-ios">{{item.progression}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 饮食建议卡片 -->
  <view class="section-header">今日饮食参考 (对应目标营养)</view>
  <view class="ios-group food-card-ios">
    <view class="food-exchange-grid">
      <view class="food-type-col">
        <text class="food-type-title">优质蛋白 (任选其一)</text>
        <view wx:for="{{foodExchange.proteinFood}}" wx:key="name" class="food-item">
          <text class="food-name">{{item.name}}</text>
          <text class="food-amount">{{item.amount}}{{item.unit}}</text>
          <text class="food-tip">{{item.tip}}</text>
        </view>
      </view>
      <view class="food-type-col">
        <text class="food-type-title">主食碳水 (任选其一)</text>
        <view wx:for="{{foodExchange.carbFood}}" wx:key="name" class="food-item">
          <text class="food-name">{{item.name}}</text>
          <text class="food-amount">{{item.amount}}{{item.unit}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="ios-group action-group-ios">
    <view class="ios-item-vertical" bindtap="toggleDeload">
      <view class="label-row">
        <text>{{isDeload ? '恢复正常强度' : '开启减载周'}}</text>
        <switch checked="{{isDeload}}" disabled color="#34c759" />
      </view>
      <view class="ios-tip">减载周: 降低 50% 容量或 10% 重量，帮助中枢神经恢复，突破平台期。</view>
    </view>
  </view>

  <!-- 参考图 Modal -->
  <view class="ios-modal" wx:if="{{showBFRef}}" bindtap="toggleBFRef">
    <view class="modal-content" catchtap="stopBubble">
      <image class="bf-image" src="/images/bf_{{bodyData.gender}}.jpg" mode="widthFix" bindtap="previewRefImage" />
      <view class="modal-close" bindtap="toggleBFRef">完成</view>
    </view>
  </view>

</view>