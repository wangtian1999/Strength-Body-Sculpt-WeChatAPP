/** target.wxss - Apple Style Purged **/
.ios-item-vertical {
  padding: 16px;
  border-bottom: 0.5px solid var(--ios-light-gray);
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.label {
  font-size: 15px;
  color: var(--ios-text-gray);
}

.link-apple {
  color: var(--ios-blue);
  font-size: 13px;
}

.ios-slider {
  margin: 0;
  padding: 8px 0;
}

.ios-value-highlight {
  font-size: 17px;
  font-weight: 600;
  color: #fff;
}

.nutrition-card-ios {
  padding: 24px;
}

.calories-header-ios {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24px;
}

.cal-val {
  font-size: 40px;
  font-weight: 700;
  letter-spacing: -1px;
}

.cal-unit {
  font-size: 13px;
  color: var(--ios-text-gray);
  margin-left: 4px;
}

.macro-grid-ios {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.macro-item-ios {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-bottom: 8px;
}

.dot.protein { background: #fff; }
.dot.carb { background: var(--ios-green); }
.dot.fat { background: #ff9500; }

.m-lab {
  font-size: 11px;
  color: var(--ios-text-gray);
  margin-bottom: 4px;
}

.m-val {
  font-size: 15px;
  font-weight: 600;
}
