<view class="container">
  <view class="large-title">规划您的目标</view>

  <!-- 训练环境 Segmented Control -->
  <view class="section-header">训练环境</view>
  <view class="segmented-control">
    <view class="segmented-item {{trainingMode === 'gym_strength' ? 'active' : ''}}" bindtap="selectMode" data-mode="gym_strength">健身房 (三大项)</view>
    <view class="segmented-item {{trainingMode === 'home_bodyweight' ? 'active' : ''}}" bindtap="selectMode" data-mode="home_bodyweight">居家 (自重)</view>
  </view>

  <!-- 训练分化 Segmented Control -->
  <view class="section-header">训练分化方式</view>
  <view class="segmented-control">
    <view class="segmented-item {{splitMode === 'full_body' ? 'active' : ''}}" bindtap="selectSplit" data-split="full_body">全身 (A/B)</view>
    <view class="segmented-item {{splitMode === 'two_split' ? 'active' : ''}}" bindtap="selectSplit" data-split="two_split">二分 (上/下)</view>
    <view class="segmented-item {{splitMode === 'three_split' ? 'active' : ''}}" bindtap="selectSplit" data-split="three_split">三分 (推/拉/腿)</view>
  </view>

  <!-- 目标详情 -->
  <view class="section-header">塑身目标 (体脂率)</view>
  <view class="ios-group">
    <view class="ios-item-vertical">
      <view class="label-row">
        <text class="label">理想体脂率: {{targetBodyFat}}%</text>
        <text class="link-apple" bindtap="toggleBFRef">参考图</text>
      </view>
      <slider class="ios-slider" min="8" max="25" step="1" value="{{targetBodyFat}}" bindchange="onFatChange" activeColor="#fff" />
      <view class="ios-tip">
      注：健力（力量增长）无特定终点，而塑身则通过体脂率量化。建议：男 12-15% | 女 19-22%。
    </view>
  </view>
</view>

<view class="btn-apple haptic-active" bindtap="saveAndNext">一键生成训练计划</view>

  <!-- 参考图 Modal -->
  <view class="ios-modal" wx:if="{{showBFRef}}" bindtap="toggleBFRef">
    <view class="modal-content" catchtap="stopBubble">
      <image class="bf-image" src="/images/bf_{{bodyData.gender}}.jpg" mode="widthFix" bindtap="previewRefImage" />
      <view class="modal-close" bindtap="toggleBFRef">完成</view>
    </view>
  </view>
</view>