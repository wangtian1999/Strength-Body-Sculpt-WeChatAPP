<view class="container">
  <view class="large-title">规划您的目标</view>

  <!-- 目标方向 Segmented Control -->
  <view class="section-header">期望方向</view>
  <view class="segmented-control">
    <view class="segmented-item {{goal === 'muscle' ? 'active' : ''}}" bindtap="selectGoal" data-goal="muscle">增肌塑形</view>
    <view class="segmented-item {{goal === 'fat_loss' ? 'active' : ''}}" bindtap="selectGoal" data-goal="fat_loss">减脂瘦身</view>
  </view>

  <!-- 训练环境 Segmented Control -->
  <view class="section-header">训练环境</view>
  <view class="segmented-control">
    <view class="segmented-item {{trainingMode === 'gym_strength' ? 'active' : ''}}" bindtap="selectMode" data-mode="gym_strength">健身房</view>
    <view class="segmented-item {{trainingMode === 'home_bodyweight' ? 'active' : ''}}" bindtap="selectMode" data-mode="home_bodyweight">居家/自重</view>
    <view class="segmented-item {{trainingMode === 'cardio' ? 'active' : ''}}" bindtap="selectMode" data-mode="cardio">有氧/HIIT</view>
  </view>

  <!-- 目标详情 -->
  <view class="section-header">目标设定</view>
  <view class="ios-group">
    <view class="ios-item-vertical">
      <view class="label-row">
        <text class="label">目标体脂率: {{targetBodyFat}}%</text>
        <text class="link-apple" bindtap="toggleBFRef">参考图</text>
      </view>
      <slider class="ios-slider" min="{{goal === 'muscle' ? 8 : 5}}" max="{{goal === 'muscle' ? 20 : 35}}" step="1" value="{{targetBodyFat}}" bindchange="onFatChange" activeColor="#fff" />
    </view>
    
    <view class="ios-item">
      <text>预估目标体重</text>
      <text class="ios-value-highlight">{{targetWeight}}kg</text>
    </view>

    <view class="ios-item">
      <text>预估达成周期</text>
      <text class="ios-value-highlight">{{estimatedWeeks}}周</text>
    </view>
  </view>

  <!-- 营养建议卡片 -->
  <view class="section-header">营养配比建议</view>
  <view class="ios-group nutrition-card-ios">
    <view class="calories-header-ios">
      <text class="cal-val">{{dailyCalories}}</text>
      <text class="cal-unit">kcal / 日</text>
    </view>
    <view class="macro-grid-ios">
      <view class="macro-item-ios">
        <view class="dot protein"></view>
        <text class="m-lab">蛋白质</text>
        <text class="m-val">{{macros.protein}}g</text>
      </view>
      <view class="macro-item-ios">
        <view class="dot carb"></view>
        <text class="m-lab">碳水</text>
        <text class="m-val">{{macros.carb}}g</text>
      </view>
      <view class="macro-item-ios">
        <view class="dot fat"></view>
        <text class="m-lab">脂肪</text>
        <text class="m-val">{{macros.fat}}g</text>
      </view>
    </view>
  </view>

  <view class="btn-apple haptic-active" bindtap="saveAndNext">一键生成训练计划</view>

  <!-- 参考图 Modal -->
  <view class="ios-modal" wx:if="{{showBFRef}}" bindtap="toggleBFRef">
    <view class="modal-content" catchtap="stopBubble">
      <image class="bf-image" src="/images/bf_{{bodyData.gender}}.jpg" mode="widthFix" bindtap="previewRefImage" />
      <view class="modal-close" bindtap="toggleBFRef">完成</view>
    </view>
  </view>
</view>