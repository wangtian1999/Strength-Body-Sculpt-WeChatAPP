/** app.wxss **/
page {
  background-color: #000000;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  line-height: 1.6;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

/* 硬核理工风格：边框、高对比、无圆角 */
.card {
  border: 2rpx solid #333333;
  padding: 30rpx;
  margin-bottom: 30rpx;
  background-color: #0a0a0a;
}

.section-title {
  font-size: 24rpx;
  color: #888888;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.big-number {
  font-size: 64rpx;
  font-weight: 800;
  font-family: 'Courier New', Courier, monospace;
}

.unit {
  font-size: 24rpx;
  color: #888888;
  margin-left: 10rpx;
}

.btn-primary {
  background-color: #ffffff;
  color: #000000;
  border-radius: 0;
  font-weight: bold;
  font-size: 32rpx;
  padding: 20rpx;
  text-align: center;
  border: none;
}

.btn-secondary {
  background-color: #000000;
  color: #ffffff;
  border: 2rpx solid #ffffff;
  border-radius: 0;
  font-weight: bold;
  font-size: 32rpx;
  padding: 20rpx;
  text-align: center;
}

.btn-outline {
  background-color: transparent;
  color: #888;
  border: 1rpx solid #333;
  border-radius: 0;
  font-size: 28rpx;
  padding: 15rpx;
  text-align: center;
}

.footer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.footer-actions button {
  flex: 1;
}

input {
  background: #111;
  border: 1rpx solid #333;
  color: white;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  display: block;
}