/** app.wxss - Apple HIG (Human Interface Guidelines) Style **/
page {
  background-color: #000000;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Icons', 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
  --ios-blue: #007aff;
  --ios-green: #34c759;
  --ios-red: #ff3b30;
  --ios-gray: #1c1c1e;
  --ios-light-gray: #2c2c2e;
  --ios-text-gray: #8e8e93;
  --radius-ios: 12px;
  line-height: 1.5;
}

.container {
  padding: 0 16px;
  box-sizing: border-box;
}

/* Apple 风格大标题 */
.large-title {
  font-size: 34px;
  font-weight: 700;
  padding: 40px 0 20px 0;
  letter-spacing: -0.5px;
}

.section-header {
  font-size: 13px;
  color: var(--ios-text-gray);
  text-transform: uppercase;
  padding-left: 16px;
  margin-bottom: 8px;
  letter-spacing: 0.5px;
}

/* iOS 分组卡片布局 */
.ios-group {
  background: var(--ios-gray);
  border-radius: var(--radius-ios);
  margin-bottom: 24px;
  overflow: hidden;
}

.ios-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 0.5px solid var(--ios-light-gray);
  min-height: 44px;
}

.ios-item:last-child {
  border-bottom: none;
}

/* Apple 风格按钮 */
.btn-apple {
  background: #ffffff;
  color: #000000;
  font-size: 17px;
  font-weight: 600;
  height: 50px;
  border-radius: var(--radius-ios);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32px 0;
}

.btn-apple:active {
  background: #f2f2f7;
}

.btn-secondary-apple {
  background: var(--ios-light-gray);
  color: #ffffff;
}

/* 分段控件 Segmented Control */
.segmented-control {
  background: var(--ios-gray);
  padding: 2px;
  border-radius: 9px;
  display: flex;
  margin-bottom: 24px;
}

.segmented-item {
  flex: 1;
  text-align: center;
  font-size: 13px;
  padding: 6px 0;
  border-radius: 7px;
  color: var(--ios-text-gray);
}

.segmented-item.active {
  background: #636366;
  color: #ffffff;
  box-shadow: 0 3px 8px rgba(0,0,0,0.12), 0 3px 1px rgba(0,0,0,0.04);
}

/* 触感模拟 - 移除动画 */
.haptic-active:active {
  /* 仅保留触感，移除视觉跳动 */
}

.footer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.footer-actions button {
  flex: 1;
}

input {
  background: #111;
  border: 1rpx solid #333;
  color: white;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  display: block;
}

/* 全局 Apple 风格弹窗 (Modal) */
.ios-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 90%;
  background: var(--ios-gray);
  border-radius: 20px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  max-height: 90vh;
  position: relative;
}

.modal-close {
  margin-top: 20px;
  color: var(--ios-blue);
  font-weight: 600;
  font-size: 17px;
  padding: 10px;
}

.help-content-ios {
  width: 100%;
}

.help-scroll-ios {
  width: 100%;
  max-height: 65vh;
}

.help-section {
  margin-bottom: 24px;
}

.help-title {
  font-size: 19px;
  font-weight: 700;
  margin-bottom: 10px;
  color: #fff;
}

.help-text {
  font-size: 15px;
  color: var(--ios-text-gray);
  line-height: 1.6;
}

.bf-image {
  width: 100%;
  border-radius: 12px;
}